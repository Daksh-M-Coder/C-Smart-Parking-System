digraph HashMap {
    graph [label="HASH MAP -- License Plate -> Slot ID\n(djb2 hash function | 20 buckets | Chaining for collisions)", fontsize=16, fontname="Helvetica", bgcolor="#f8f9fa", pad=0.5];
    node  [fontname="Helvetica", fontsize=11];
    rankdir=LR;
    subgraph cluster_buckets {
        label="Hash Buckets";
        style=filled; fillcolor="#ecf0f1";
        B0 [shape=record, style=filled, fillcolor="#bdc3c7", fontcolor=white, label="bucket[0]"];
        B1 [shape=record, style=filled, fillcolor="#bdc3c7", fontcolor=white, label="bucket[1]"];
        B2 [shape=record, style=filled, fillcolor="#bdc3c7", fontcolor=white, label="bucket[2]"];
        B3 [shape=record, style=filled, fillcolor="#bdc3c7", fontcolor=white, label="bucket[3]"];
        B4 [shape=record, style=filled, fillcolor="#9b59b6", fontcolor=white, label="bucket[4]"];
        B5 [shape=record, style=filled, fillcolor="#bdc3c7", fontcolor=white, label="bucket[5]"];
        B6 [shape=record, style=filled, fillcolor="#bdc3c7", fontcolor=white, label="bucket[6]"];
        B7 [shape=record, style=filled, fillcolor="#9b59b6", fontcolor=white, label="bucket[7]"];
        B8 [shape=record, style=filled, fillcolor="#bdc3c7", fontcolor=white, label="bucket[8]"];
        B9 [shape=record, style=filled, fillcolor="#bdc3c7", fontcolor=white, label="bucket[9]"];
        B10 [shape=record, style=filled, fillcolor="#bdc3c7", fontcolor=white, label="bucket[10]"];
        B11 [shape=record, style=filled, fillcolor="#bdc3c7", fontcolor=white, label="bucket[11]"];
        B12 [shape=record, style=filled, fillcolor="#bdc3c7", fontcolor=white, label="bucket[12]"];
        B13 [shape=record, style=filled, fillcolor="#bdc3c7", fontcolor=white, label="bucket[13]"];
        B14 [shape=record, style=filled, fillcolor="#9b59b6", fontcolor=white, label="bucket[14]"];
        B15 [shape=record, style=filled, fillcolor="#9b59b6", fontcolor=white, label="bucket[15]"];
        B16 [shape=record, style=filled, fillcolor="#9b59b6", fontcolor=white, label="bucket[16]"];
        B17 [shape=record, style=filled, fillcolor="#9b59b6", fontcolor=white, label="bucket[17]"];
        B18 [shape=record, style=filled, fillcolor="#bdc3c7", fontcolor=white, label="bucket[18]"];
        B19 [shape=record, style=filled, fillcolor="#bdc3c7", fontcolor=white, label="bucket[19]"];
        B0 -> B1 [style=invis];
        B1 -> B2 [style=invis];
        B2 -> B3 [style=invis];
        B3 -> B4 [style=invis];
        B4 -> B5 [style=invis];
        B5 -> B6 [style=invis];
        B6 -> B7 [style=invis];
        B7 -> B8 [style=invis];
        B8 -> B9 [style=invis];
        B9 -> B10 [style=invis];
        B10 -> B11 [style=invis];
        B11 -> B12 [style=invis];
        B12 -> B13 [style=invis];
        B13 -> B14 [style=invis];
        B14 -> B15 [style=invis];
        B15 -> B16 [style=invis];
        B16 -> B17 [style=invis];
        B17 -> B18 [style=invis];
        B18 -> B19 [style=invis];
    }
    NULL0 [shape=rectangle, style=filled, fillcolor="#95a5a6", fontcolor=white, label="NULL"];
    B0 -> NULL0;
    NULL1 [shape=rectangle, style=filled, fillcolor="#95a5a6", fontcolor=white, label="NULL"];
    B1 -> NULL1;
    NULL2 [shape=rectangle, style=filled, fillcolor="#95a5a6", fontcolor=white, label="NULL"];
    B2 -> NULL2;
    NULL3 [shape=rectangle, style=filled, fillcolor="#95a5a6", fontcolor=white, label="NULL"];
    B3 -> NULL3;
    H4_0 [shape=record, style=filled, fillcolor="#f39c12", fontcolor=white, label="{HR26KL8901 | -> Slot 10}"];
    B4 -> H4_0 [label="hash=4"];
    H4_1 [shape=record, style=filled, fillcolor="#e67e22", fontcolor=white, label="{MH01XY9999 | -> Slot 7}"];
    H4_0 -> H4_1;
    H4_2 [shape=record, style=filled, fillcolor="#e67e22", fontcolor=white, label="{PB10ZZ1111 | -> Slot 1}"];
    H4_1 -> H4_2;
    NULLH4 [shape=rectangle, style=filled, fillcolor="#95a5a6", fontcolor=white, label="NULL"];
    H4_2 -> NULLH4 [label="next"];
    NULL5 [shape=rectangle, style=filled, fillcolor="#95a5a6", fontcolor=white, label="NULL"];
    B5 -> NULL5;
    NULL6 [shape=rectangle, style=filled, fillcolor="#95a5a6", fontcolor=white, label="NULL"];
    B6 -> NULL6;
    H7_0 [shape=record, style=filled, fillcolor="#f39c12", fontcolor=white, label="{KA03MN9012 | -> Slot 2}"];
    B7 -> H7_0 [label="hash=7"];
    NULLH7 [shape=rectangle, style=filled, fillcolor="#95a5a6", fontcolor=white, label="NULL"];
    H7_0 -> NULLH7 [label="next"];
    NULL8 [shape=rectangle, style=filled, fillcolor="#95a5a6", fontcolor=white, label="NULL"];
    B8 -> NULL8;
    NULL9 [shape=rectangle, style=filled, fillcolor="#95a5a6", fontcolor=white, label="NULL"];
    B9 -> NULL9;
    NULL10 [shape=rectangle, style=filled, fillcolor="#95a5a6", fontcolor=white, label="NULL"];
    B10 -> NULL10;
    NULL11 [shape=rectangle, style=filled, fillcolor="#95a5a6", fontcolor=white, label="NULL"];
    B11 -> NULL11;
    NULL12 [shape=rectangle, style=filled, fillcolor="#95a5a6", fontcolor=white, label="NULL"];
    B12 -> NULL12;
    NULL13 [shape=rectangle, style=filled, fillcolor="#95a5a6", fontcolor=white, label="NULL"];
    B13 -> NULL13;
    H14_0 [shape=record, style=filled, fillcolor="#f39c12", fontcolor=white, label="{MH43CD2345 | -> Slot 8}"];
    B14 -> H14_0 [label="hash=14"];
    NULLH14 [shape=rectangle, style=filled, fillcolor="#95a5a6", fontcolor=white, label="NULL"];
    H14_0 -> NULLH14 [label="next"];
    H15_0 [shape=record, style=filled, fillcolor="#f39c12", fontcolor=white, label="{RJ14GH0123 | -> Slot 9}"];
    B15 -> H15_0 [label="hash=15"];
    NULLH15 [shape=rectangle, style=filled, fillcolor="#95a5a6", fontcolor=white, label="NULL"];
    H15_0 -> NULLH15 [label="next"];
    H16_0 [shape=record, style=filled, fillcolor="#f39c12", fontcolor=white, label="{UP32EF6789 | -> Slot 4}"];
    B16 -> H16_0 [label="hash=16"];
    NULLH16 [shape=rectangle, style=filled, fillcolor="#95a5a6", fontcolor=white, label="NULL"];
    H16_0 -> NULLH16 [label="next"];
    H17_0 [shape=record, style=filled, fillcolor="#f39c12", fontcolor=white, label="{DL4CAB5678 | -> Slot 6}"];
    B17 -> H17_0 [label="hash=17"];
    H17_1 [shape=record, style=filled, fillcolor="#e67e22", fontcolor=white, label="{WB20IJ4567 | -> Slot 5}"];
    H17_0 -> H17_1;
    NULLH17 [shape=rectangle, style=filled, fillcolor="#95a5a6", fontcolor=white, label="NULL"];
    H17_1 -> NULLH17 [label="next"];
    NULL18 [shape=rectangle, style=filled, fillcolor="#95a5a6", fontcolor=white, label="NULL"];
    B18 -> NULL18;
    NULL19 [shape=rectangle, style=filled, fillcolor="#95a5a6", fontcolor=white, label="NULL"];
    B19 -> NULL19;
    ColNote [shape=plaintext, label="ORANGE nodes = collision in same bucket\nWalk the chain to find the right plate"];
}
