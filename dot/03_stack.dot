digraph Stack {
    graph [label="LOG STACK (LIFO -- Last In First Out)\nEntry/Exit history -- most recent at TOP", fontsize=16, fontname="Helvetica", bgcolor="#f8f9fa", pad=0.5];
    node  [fontname="Helvetica", fontsize=11];
    rankdir=TB;
    TOP [shape=ellipse, style=filled, fillcolor="#e67e22", fontcolor=white, label="TOP (index=14)\n<- PUSH/POP here"];
    S14 [shape=record, style=filled, fillcolor="#2ecc71", fontcolor=white, label="{ENTRY [index=14] | Slot 7 | MH01XY9999 | CAR | Fee: Rs.0 | 2026-05-09 14:11:30}"];
