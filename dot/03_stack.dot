    S6 -> S5 [label="below"];
    S4 [shape=record, style=filled, fillcolor="#2ecc71", fontcolor=white, label="{ENTRY [index=4] | Slot 5 | WB20IJ4567 | BIKE | Fee: Rs.0 | 2025-05-08 16:36:40}"];
    S5 -> S4 [label="below"];
    S3 [shape=record, style=filled, fillcolor="#2ecc71", fontcolor=white, label="{ENTRY [index=3] | Slot 4 | UP32EF6789 | BIKE | Fee: Rs.0 | 2025-05-08 16:26:40}"];
