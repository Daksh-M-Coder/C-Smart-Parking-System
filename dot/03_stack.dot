    S9 -> S8 [label="below"];
    S7 [shape=record, style=filled, fillcolor="#2ecc71", fontcolor=white, label="{ENTRY [index=7] | Slot 8 | MH43CD2345 | CAR | Fee: Rs.0 | 2025-05-08 17:06:40}"];
    S8 -> S7 [label="below"];
    S6 [shape=record, style=filled, fillcolor="#2ecc71", fontcolor=white, label="{ENTRY [index=6] | Slot 7 | TN09XY3456 | CAR | Fee: Rs.0 | 2025-05-08 16:56:40}"];
    S7 -> S6 [label="below"];
