    S13 [shape=record, style=filled, fillcolor="#e74c3c", fontcolor=white, label="{EXIT [index=13] | Slot 7 | TN09XY3456 | CAR | Fee: Rs.439100 | 2026-05-09 14:11:30}"];
    S14 -> S13 [label="below"];
    S12 [shape=record, style=filled, fillcolor="#e74c3c", fontcolor=white, label="{EXIT [index=12] | Slot 3 | GJ01HH7890 | BIKE | Fee: Rs.175640 | 2026-05-09 14:10:43}"];
    S13 -> S12 [label="below"];
    S11 [shape=record, style=filled, fillcolor="#2ecc71", fontcolor=white, label="{ENTRY [index=11] | Slot 1 | PB10ZZ1111 | BIKE | Fee: Rs.0 | 2026-05-09 14:09:23}"];
